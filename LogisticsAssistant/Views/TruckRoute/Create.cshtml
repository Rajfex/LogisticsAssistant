@model TruckRouteViewModel

@{
    ViewData["Title"] = "Add truck route";
}

<h1>Add truck route</h1>

<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" method="post">
            <div class="form-group">
                <label asp-for="Distance" class="control-label"></label>
                <input asp-for="Distance" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="BreakFrequency" class="control-label"></label>
                <input asp-for="BreakFrequency" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="Date" class="control-label"></label>
                <input asp-for="Date" type="datetime-local" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="TruckId" class="control-label"></label>
                <select asp-for="TruckId" asp-items="ViewBag.Trucks" class="form-control">
                    <option value="">Select truck</option>
                </select>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>