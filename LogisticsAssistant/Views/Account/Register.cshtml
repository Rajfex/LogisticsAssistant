@model RegisterViewModel

@{
    ViewData["Title"] = "Rejestracja";
}

<h2>Utwórz nowe konto</h2>

<div class="row">
    <div class="col-md-4">
        <form asp-action="Register" method="post">
            <div class="form-group">
                <label asp-for="Name">Login</label>
                <input asp-for="Name" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="Password">Hasło</label>
                <input asp-for="Password" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword">Powtórz hasło</label>
                <input asp-for="ConfirmPassword" class="form-control" />
            </div>

            <button type="submit" class="btn btn-success mt-3">Zarejestruj się</button>
        </form>
    </div>
</div>